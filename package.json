{
  "name": "kryptoexpress-sdk",
  "version": "0.1.1",
  "description": "TypeScript-first SDK for the KryptoExpress API.",
  "license": "MIT",
  "author": "OpenAI Codex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryptoexpress/kryptoexpress-typescript.git"
  },
  "homepage": "https://github.com/kryptoexpress/kryptoexpress-typescript#readme",
  "bugs": {
    "url": "https://github.com/kryptoexpress/kryptoexpress-typescript/issues"
  },
  "keywords": [
    "kryptoexpress",
    "crypto",
    "payments",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "powershell -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "lint": "eslint src test --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
